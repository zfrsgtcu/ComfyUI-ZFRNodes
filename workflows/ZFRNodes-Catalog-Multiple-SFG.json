n}"]},{"id":33,"type":"OllamaGenerateV2","pos":[5474.726876996057,383.8969237623014],"size":[411.2801020463876,294],"flags":{},"order":8,"mode":0,"inputs":[{"localized_name":"connectivity","name":"connectivity","shape":7,"type":"OLLAMA_CONNECTIVITY","link":82},{"localized_name":"options","name":"options","shape":7,"type":"OLLAMA_OPTIONS","link":null},{"localized_name":"images","name":"images","shape":7,"type":"IMAGE","link":101},{"localized_name":"context","name":"context","shape":7,"type":"OLLAMA_CONTEXT","link":null},{"localized_name":"meta","name":"meta","shape":7,"type":"OLLAMA_META","link":null},{"localized_name":"system","name":"system","type":"STRING","widget":{"name":"system"},"link":121},{"localized_name":"prompt","name":"prompt","type":"STRING","widget":{"name":"prompt"},"link":84},{"localized_name":"think","name":"think","type":"BOOLEAN","widget":{"name":"think"},"link":null},{"localized_name":"keep_context","name":"keep_context","type":"BOOLEAN","widget":{"name":"keep_context"},"link":null},{"localized_name":"format","name":"format","type":"COMBO","widget":{"name":"format"},"link":null}],"outputs":[{"localized_name":"result","name":"result","type":"STRING","links":[86]},{"localized_name":"thinking","name":"thinking","type":"STRING","links":null},{"localized_name":"context","name":"context","type":"OLLAMA_CONTEXT","links":null},{"localized_name":"meta","name":"meta","type":"OLLAMA_META","links":null}],"title":"Creator Image Generator","properties":{"cnr_id":"comfyui-ollama","ver":"2.1.0","Node name for S&R":"OllamaGenerateV2"},"widgets_values":["","Create your prompts.",false,false,"json"]},{"id":31,"type":"OllamaGenerateV2","pos":[5046.580088600225,385.92958768346614],"size":[414.95911054409135,295.55277216243746],"flags":{},"order":7,"mode":0,"inputs":[{"localized_name":"connectivity","name":"connectivity","shape":7,"type":"OLLAMA_CONNECTIVITY","link":78},{"localized_name":"options","name":"options","shape":7,"type":"OLLAMA_OPTIONS","link":null},{"local