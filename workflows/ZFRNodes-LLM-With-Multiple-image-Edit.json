0 words can be enough.\nUse action verbs: Change, Replace, Add, Remove, Turn, Make\nFor text in image: Replace '[old]' with '[new]'\nFor colors: use hex codes — Change the jacket color to #C44536\nFor identity-sensitive edits (face, outfit on person): add while preserving facial features and pose\nFor partial changes: add Change nothing else at the end\nNo vague words: \"make it better\", \"improve\", \"fix\", \"enhance\"\n\nExamples:\n\nChange it to Night\nReplace the background with a sunset beach\nChange the shirt color to #8bc4bb\nReplace the wolf with a polar bear without headphones\nAdd snow to the scene, change nothing else\nChange the woman's outfit to a bold fuchsia dress while preserving her pose and facial features\n\nOutput the prompt only.","",false,false,"text"]}],"groups":[],"links":[{"id":3,"origin_id":7,"origin_slot":0,"target_id":5,"target_slot":0,"type":"OLLAMA_CONNECTIVITY"},{"id":5,"origin_id":-10,"origin_slot":0,"target_id":7,"target_slot":0,"type":"STRING"},{"id":6,"origin_id":-10,"origin_slot":1,"target_id":7,"target_slot":1,"type":"COMBO"},{"id":7,"origin_id":-10,"origin_slot":2,"target_id":5,"target_slot":2,"type":"IMAGE"},{"id":8,"origin_id":-10,"origin_slot":3,"target_id":5,"target_slot":6,"type":"STRING"},{"id":10,"origin_id":5,"origin_slot":0,"target_id":-20,"target_slot":0,"type":"STRING"}],"extra":{}}]},"config":{},"extra":{"ds":{"scale":0.9229599817706492,"offset":[3027.0318160904353,1944.1148370199717]}},"version":0.4}